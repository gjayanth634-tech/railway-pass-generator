/* ===== PAYMENT PAGE MODERN DESIGN ===== */

.payment-page {
    margin: 0;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
}

/* Glass effect card */
.payment-container {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(12px);
    padding: 40px;
    width: 420px;
    border-radius: 18px;
    color: white;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6);
    animation: fadeIn 0.6s ease-in-out;
}

/* Title */
.payment-container h2 {
    text-align: center;
    margin-bottom: 25px;
    font-size: 26px;
}

/* Payment options */
.payment-option {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 12px 15px;
    margin: 12px 0;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.08);
    cursor: pointer;
    transition: 0.3s ease;
}

.payment-option input[type="radio"] {
    appearance: none;
    width: 18px;
    height: 18px;
    border: 2px solid orange;
    border-radius: 50%;
    cursor: pointer;
    position: relative;
}

/* Inner dot when selected */
.payment-option input[type="radio"]:checked {
    background-color: orange;
}


/* Button */
.pay-btn {
    width: 100%;
    padding: 14px;
    margin-top: 25px;
    background: linear-gradient(45deg, orange, darkorange);
    border: none;
    border-radius: 10px;
    font-size: 17px;
    font-weight: bold;
    color: white;
    cursor: pointer;
    transition: 0.3s ease;
}

.pay-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 20px rgba(255, 140, 0, 0.6);
}

/* Animation */
@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(-20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.title {
    text-align: center;
    margin-bottom: 25px;
    font-size: 28px;
    font-weight: bold;
}
.bottom-text {
    text-align: center;
    margin-top: 20px;
    font-size: 16px;
    color: #ddd;
}

.bottom-text a {
    color: #ff9800;
    font-weight: bold;
    text-decoration: none;
    margin-left: 5px;
    transition: 0.3s;
}

.bottom-text a:hover {
    color: #ffc107;
    text-decoration: underline;
}

select {
    width: 100%;
    padding: 14px;
    margin-bottom: 18px;
    border-radius: 10px;
    border: none;
    font-size: 15px;
    outline: none;
    background: rgba(255,255,255,0.9);
    cursor: pointer;
}
