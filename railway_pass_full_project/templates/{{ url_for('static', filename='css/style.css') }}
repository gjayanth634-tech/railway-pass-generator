    align-items: center;
}

/* Payment card */
.payment-container {
    background: rgba(0, 0, 0, 0.9);
    padding: 30px;
    width: 400px;
    border-radius: 12px;
    color: white;
}

/* Title */
.payment-container h2 {
    text-align: center;
    margin-bottom: 20px;
}

/* Payment options */
.payment-option {
    display: flex;
    align-items: center;
    justify-content: flex-start;  /* THIS FIXES YOUR ERROR */
    gap: 12px;
    margin: 15px 0;
}

/* Radio button size */
.payment-option input[type="radio"] {
    transform: scale(1.2);
    cursor: pointer;
    justify-content: space-between;

}

