/* =========================
   RESET
========================= */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* =========================
   BODY BACKGROUND
========================= */
body {
    margin: 0;
    padding: 0;
    height: 100vh;
    display: flex;
    justify-content: center;   /* Horizontal center */
    align-items: center; 
    background: url("../image/railway-station.jpg") no-repeat center center fixed;
    background-size: cover;
    font-family: Arial, sans-serif;
}


/* =========================
   MAIN CONTAINER CARD
========================= */
.container {
    width: 420px;
    padding: 40px;
    border-radius: 20px;

    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(15px);

    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.7);

    color: white;
    animation: fadeIn 0.6s ease;
}


/* =========================
   TOP BAR (TITLE + LOGOUT)
========================= */
.top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
}

.top-bar h2 {
    font-size: 22px;
    font-weight: 600;
}

.logout {
    color: #ff9800;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
}

.logout:hover {
    text-decoration: underline;
}

.link-text {
    text-align: center;
    margin-top: 15px;
}

.link-text a {
    color: orange;
    text-decoration: none;
    font-weight: bold;
}

/* =========================
   FORM INPUTS
========================= */
input {
    width: 100%;
    padding: 14px;
    margin-bottom: 18px;
    border-radius: 10px;
    border: none;
    font-size: 15px;
    outline: none;
    background: rgba(255,255,255,0.9);
}

input:focus {
    box-shadow: 0 0 10px orange;
    transform: scale(1.02);
    transition: 0.2s;
}


/* =========================
   BUTTON
========================= */
button {
    width: 100%;
    padding: 14px;
    border-radius: 12px;
    border: none;
    background: linear-gradient(45deg, #ff9800, #ff7b00);
    color: white;
    font-size: 17px;
    font-weight: bold;
    cursor: pointer;
    transition: 0.3s ease;
}

button:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(255,140,0,0.6);
}


/* =========================
   ERROR MESSAGE
========================= */
.error {
    background: rgba(255, 0, 0, 0.2);
    padding: 8px;
    border-radius: 6px;
    margin-bottom: 15px;
    text-align: center;
    font-size: 14px;
}

/* =========================
   RESPONSIVE (Mobile)
========================= */
@media (max-width: 480px) {
    .container {
        width: 90%;
        padding: 25px;
    }
}
